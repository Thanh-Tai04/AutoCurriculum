@model AutoCurriculum.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-5">
                <h3 class="text-center mb-4 fw-bold text-primary">Quên Mật Khẩu?</h3>
                <p class="text-center text-muted mb-4">Nhập email của bạn để hệ thống gửi mã xác nhận (OTP) đặt lại mật khẩu.</p>

                <form id="formForgotPassword" asp-action="ForgotPassword" method="post">
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" required />
                        <label asp-for="Email"></label>
                        <span asp-validation-for="Email" class="text-danger text-sm d-block mt-1"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill">
                        Gửi mã xác nhận
                    </button>

                    <div class="text-center mt-4 border-top pt-3">
                        <a asp-action="Login" class="text-decoration-none text-muted">
                            <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function () {
            // Bắt sự kiện khi người dùng bấm nút Submit
            $('#formForgotPassword').on('submit', function (e) {
                // Kiểm tra xem định dạng Email đã nhập đúng chưa
                if ($(this).valid()) {
                    // Chặn form gửi đi ngay lập tức
                    e.preventDefault();
                    let form = this;

                    // Bung popup Loading
                    Swal.fire({
                        title: 'Đang gửi mã OTP...',
                        text: 'Vui lòng đợi trong giây lát, hệ thống đang cấu hình gửi email cho bạn.',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    // Đợi 0.5s cho popup hiện lên mượt mà rồi mới thực sự gửi dữ liệu về Controller
                    setTimeout(() => {
                        form.submit();
                    }, 500); 
                }
            });
        });
    </script>
}