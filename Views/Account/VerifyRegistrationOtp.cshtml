@{
    ViewData["Title"] = "Kích hoạt tài khoản";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-5 text-center">
                <div class="mb-4">
                    <h1 class="display-4">✉️</h1>
                </div>
                <h3 class="card-title text-success fw-bold mb-3">Xác nhận Tài khoản</h3>
                <p class="text-muted mb-4">
                    Chúng tôi vừa gửi một mã xác nhận gồm 6 chữ số đến email của bạn để hoàn tất quá trình đăng ký.
                </p>

                <form asp-controller="Account" asp-action="VerifyRegistrationOtp" method="post">
                    <div asp-validation-summary="All" class="text-danger text-start mb-3 fw-bold"></div>

                    <div class="form-floating mb-4">
                        <input type="text" name="otp" class="form-control form-control-lg text-center fs-2 fw-bold text-success tracking-widest" id="otpInput" placeholder="123456" maxlength="6" required autocomplete="off" autofocus>
                        <label for="otpInput">Nhập 6 số OTP tại đây</label>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 fw-bold rounded-pill shadow-sm">
                        Xác nhận
                    </button>
                </form>

                <div class="mt-4">
                    <a asp-action="Register" class="text-decoration-none text-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại trang Đăng ký
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-widest { letter-spacing: 0.5em; }
</style>