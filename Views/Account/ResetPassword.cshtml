@model AutoCurriculum.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm p-4 border-0 rounded-4">
            <h3 class="text-center mb-4 fw-bold text-primary">Tạo Mật Khẩu Mới</h3>
            
            <form id="formResetPassword" asp-action="ResetPassword" method="post">
                <input type="hidden" asp-for="Email" />
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                <div class="mb-3">
                    <label class="form-label text-muted">Mã xác nhận (OTP) từ Email</label>
                    <input asp-for="Token" class="form-control text-center fw-bold fs-5 tracking-widest" required placeholder="Nhập 6 số" />
                    <span asp-validation-for="Token" class="text-danger text-sm mt-1 d-block"></span>
                </div>
                
                <div class="mb-4">
                    <label class="form-label text-muted">Mật khẩu mới</label>
                    <div class="position-relative">
                        <input asp-for="NewPassword" type="password" class="form-control pe-5" required placeholder="Nhập mật khẩu mới" />
                        <i class="bi bi-eye-slash text-muted position-absolute top-50 end-0 translate-middle-y me-3 toggle-password" style="cursor: pointer; z-index: 10;"></i>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger text-sm d-block mt-1"></span>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill">
                    Cập nhật mật khẩu
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function () {
            // 1. Tính năng Ẩn/Hiện mật khẩu
            $('.toggle-password').click(function () {
                let input = $(this).prev('input');
                if (input.attr('type') === "password") {
                    input.attr('type', 'text');
                    $(this).removeClass('bi-eye-slash').addClass('bi-eye');
                } else {
                    input.attr('type', 'password');
                    $(this).removeClass('bi-eye').addClass('bi-eye-slash');
                }
            });

            // 2. Tính năng Hiển thị Loading khi bấm nút
            $('#formResetPassword').on('submit', function (e) {
                // Kiểm tra xem mật khẩu nhập vào đã ĐÚNG QUY ĐỊNH chưa
                if ($(this).valid()) {
                    // Nếu đúng rồi -> Chặn việc load lại trang ngay lập tức
                    e.preventDefault();
                    let form = this;

                    // Hiện popup xoay xoay đẹp mắt
                    Swal.fire({
                        title: 'Đang xử lý...',
                        text: 'Hệ thống đang lưu mật khẩu mới của bạn.',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    // Cho form gửi dữ liệu đi sau 0.5s để người dùng kịp nhìn thấy hiệu ứng
                    setTimeout(() => {
                        form.submit();
                    }, 500); 
                }
                // Nếu mật khẩu sai quy định, hàm .valid() sẽ tự động chặn lại và hiện chữ đỏ, không hiện Loading
            });
        });
    </script>
}