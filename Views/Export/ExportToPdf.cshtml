@model AutoCurriculum.Models.Topic
@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Giáo trình @Model.TopicName</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    
    <style>
        /* 1. RESET TOÀN BỘ, TRẢ LẠI SỰ KIỂM SOÁT CHO ROTATIVA */
        body { 
            font-family: "Times New Roman", Times, serif; 
            font-size: 13pt; 
            line-height: 1.5; 
            text-align: justify;
            color: #000; 
            background-color: #fff;
        }

        /* 2. CẤU HÌNH NGẮT TRANG TUYỆT ĐỐI AN TOÀN */
        .page-break {
            page-break-before: always !important; 
        }

        h1, h2, h3, h4, h5, h6 {
            color: #000 !important; 
            font-weight: bold;
            page-break-after: avoid !important; /* Không rớt tiêu đề */
            page-break-inside: avoid !important;
        }

        p, ul, li, div { 
            page-break-inside: auto !important; /* Cho phép Rotativa tự do cầm kéo cắt đôi văn bản giữa 2 trang */
        }

        /* 3. ĐỊNH DẠNG CÁC THÀNH PHẦN */
        .cover-page { text-align: center; padding-top: 150px; }
        .cover-title-1 { font-size: 24pt; margin-bottom: 20px; }
        .cover-title-2 { font-size: 32pt; margin-bottom: 80px; text-transform: uppercase; }
        .cover-meta { font-size: 14pt; margin-top: 10px; }

        .toc-title { text-align: center; font-size: 20pt; margin-bottom: 30px; text-transform: uppercase; }
        .toc-chapter { font-size: 14pt; margin-top: 15px; margin-bottom: 5px; font-weight: bold; }
        .toc-lesson { font-size: 13pt; margin-left: 30px; margin-bottom: 5px; }
        
        .chapter-header { text-align: center; font-size: 20pt; text-transform: uppercase; margin-bottom: 40px; }
        .lesson-break { margin-top: 20px; } 

        /* 4. CHỐNG TRÀN KHỐI CODE & CHO PHÉP CẮT KHỐI CODE */
        pre {
            background-color: #f4f6f8;
            border: 1px solid #e1e4e8;
            padding: 12px;
            white-space: pre-wrap !important; 
            word-wrap: break-word !important; 
            word-break: break-all !important; 
            max-width: 100%; 
            page-break-inside: auto !important; /* Quan trọng: Cho phép cắt đôi khối code nếu dài sang trang sau */
        }
        pre code { font-family: Consolas, Monaco, 'Courier New', monospace; font-size: 10pt; color: #24292e; }

    </style>
</head>
<body>

    <div class="cover-page"> 
        <h1 class="cover-title-1">GIÁO TRÌNH VÀ TÀI LIỆU</h1>
        <h2 class="cover-title-2">@Model.TopicName</h2>
        
        <div style="margin-top: 150px;"> 
            <p class="cover-meta">Biên soạn bởi: Hệ thống AutoCurriculum</p>
            <p class="cover-meta">Ngày xuất bản: @DateTime.Now.ToString("dd/MM/yyyy")</p>
        </div>
    </div>

    <h2 class="toc-title page-break">Mục lục</h2>
    @if (Model.Chapters != null)
    {
        @foreach (var chapter in Model.Chapters.OrderBy(c => c.ChapterOrder))
        {
            <div class="toc-chapter">
                Chương @chapter.ChapterOrder: @chapter.ChapterTitle
            </div>
            @if (chapter.Lessons != null)
            {
                <div class="list-unstyled">
                    @foreach (var lesson in chapter.Lessons.OrderBy(l => l.LessonOrder))
                    {
                        <div class="toc-lesson">
                            @chapter.ChapterOrder.@lesson.LessonOrder: @lesson.LessonTitle
                        </div>
                    }
                </div>
            }
        }
    }

    @if (Model.Chapters != null)
    {
        @foreach (var chapter in Model.Chapters.OrderBy(c => c.ChapterOrder))
        {
            <h2 class="chapter-header page-break">
                Chương @chapter.ChapterOrder: @chapter.ChapterTitle
            </h2>
            
            @if (chapter.Lessons != null)
            {
                @foreach (var lesson in chapter.Lessons.OrderBy(l => l.LessonOrder))
                {
                    <div class="lesson-break">
                        @if (lesson.Contents != null && lesson.Contents.Any())
                        {
                            @foreach (var content in lesson.Contents)
                            {
                                @Html.Raw(content.ContentText)
                            }
                        }
                        else
                        {
                            <h3>@chapter.ChapterOrder.@lesson.LessonOrder @lesson.LessonTitle</h3>
                            <p style="font-style: italic;">Nội dung bài học chưa được biên soạn.</p>
                        }
                    </div>
                }
            }
        }
    }
    
    <h2 class="toc-title page-break" style="margin-top: 40px;">Tài liệu tham khảo</h2>
    
    <p>Tài liệu giáo trình này được biên soạn và tổng hợp tự động bởi hệ thống Trí tuệ Nhân tạo (AI) <b>AutoCurriculum</b>.</p>
    
    <p><strong>Nguồn dữ liệu tham chiếu chính:</strong></p>
    <ul>
        @if (Model.Source != null)
        {
            <li style="margin-bottom: 10px;">
                <b>@Model.Source.SourceName</b> 
                @if (!string.IsNullOrEmpty(Model.Source.SourceUrl))
                {
                    <span>- Truy cập tại: <a href="@Model.Source.SourceUrl" target="_blank" style="color: blue; text-decoration: underline;">@Model.Source.SourceUrl</a></span>
                }
            </li>
        }
        else
        {
            <li>Hệ thống bách khoa toàn thư mở Wikipedia.</li>
        }
        <li>Các tài liệu học thuật định dạng mở trên Internet (Open Educational Resources).</li>
    </ul>
    
    <p style="margin-top: 30px; font-style: italic;">
        * Lưu ý: Nội dung do AI tự động trích xuất và sắp xếp, phục vụ cho mục đích học tập và tham khảo nội bộ.
    </p>

</body>
</html>