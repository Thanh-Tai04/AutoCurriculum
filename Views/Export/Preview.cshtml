@model AutoCurriculum.Models.Topic
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.TopicName — AutoCurriculum</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />

    <style>
        /* ══════════════════════════════════════════════
           BIẾN TOÀN CỤC
        ══════════════════════════════════════════════ */
        :root {
            --font-body:    'DM Sans', sans-serif;
            --font-content: 'Lora', serif;
            --accent:       #1D9E75;
            --accent-light: #E1F5EE;
            --ink:          #1a1a1a;
            --muted:        #6b7280;
            --border:       #e5e7eb;
            --surface:      #f9fafb;
            --sidebar-w:    260px;
            --toolbar-h:    52px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font-body);
            font-size: 15px;
            color: var(--ink);
            background: var(--surface);
            line-height: 1.6;
        }

        /* ══════════════════════════════════════════════
           TOOLBAR
        ══════════════════════════════════════════════ */
        .cv-toolbar {
            position: fixed; top: 0; left: 0; right: 0;
            height: var(--toolbar-h);
            background: #fff;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            z-index: 100;
        }
        .cv-toolbar-left { display: flex; align-items: center; gap: 12px; }
        .cv-toolbar-logo {
            font-size: 13px; font-weight: 500;
            color: var(--accent); letter-spacing: .02em;
        }
        .cv-toolbar-sep { width: 1px; height: 20px; background: var(--border); }
        .cv-toolbar-title {
            font-size: 14px; color: var(--muted);
            max-width: 400px; white-space: nowrap;
            overflow: hidden; text-overflow: ellipsis;
        }
        .cv-toolbar-actions { display: flex; gap: 8px; align-items: center; }
        .cv-btn {
            font-family: var(--font-body);
            font-size: 13px; font-weight: 500;
            padding: 6px 14px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--ink);
            cursor: pointer;
            text-decoration: none;
            display: inline-flex; align-items: center; gap: 6px;
            transition: background .15s;
        }
        .cv-btn:hover { background: var(--surface); }
        .cv-btn-primary {
            background: var(--accent); color: #fff;
            border-color: var(--accent);
        }
        .cv-btn-primary:hover { background: #198a65; }

        /* ══════════════════════════════════════════════
           LAYOUT: SIDEBAR + MAIN
        ══════════════════════════════════════════════ */
        .cv-layout {
            display: flex;
            padding-top: var(--toolbar-h);
            min-height: 100vh;
        }

        /* SIDEBAR */
        .cv-sidebar {
            width: var(--sidebar-w);
            flex-shrink: 0;
            position: fixed;
            top: var(--toolbar-h);
            left: 0;
            bottom: 0;
            overflow-y: auto;
            background: #fff;
            border-right: 1px solid var(--border);
            padding: 1.25rem 0 2rem;
        }
        .cv-sidebar-header {
            padding: 0 1.25rem 1rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: .75rem;
        }
        .cv-sidebar-label {
            font-size: 10px; font-weight: 500;
            letter-spacing: .08em; text-transform: uppercase;
            color: var(--muted); margin-bottom: 6px;
        }
        .cv-sidebar-topic {
            font-size: 13px; font-weight: 500;
            color: var(--ink); line-height: 1.4;
        }
        .cv-toc-chapter {
            padding: 10px 1.25rem 4px;
            font-size: 11px; font-weight: 500;
            letter-spacing: .06em; text-transform: uppercase;
            color: var(--muted);
        }
        .cv-toc-lesson {
            display: block;
            padding: 5px 1.25rem 5px 1.75rem;
            font-size: 13px; color: var(--muted);
            text-decoration: none;
            border-left: 2px solid transparent;
            transition: all .15s;
        }
        .cv-toc-lesson:hover {
            color: var(--ink);
            background: var(--accent-light);
            border-left-color: var(--accent);
        }

        /* MAIN CONTENT */
        .cv-main {
            margin-left: var(--sidebar-w);
            flex: 1;
            padding: 2.5rem 3rem 5rem;
            max-width: calc(var(--sidebar-w) + 780px);
        }
        .cv-content-inner { max-width: 700px; }

        /* CHAPTER */
        .cv-chapter { margin-bottom: 3.5rem; }
        .cv-chapter-badge {
            display: inline-flex; align-items: center;
            font-size: 11px; font-weight: 500;
            color: #0F6E56; background: var(--accent-light);
            padding: 3px 10px; border-radius: 20px;
            margin-bottom: 10px;
        }
        .cv-chapter-title {
            font-family: var(--font-content);
            font-size: 22px; font-weight: 600;
            color: var(--ink);
            padding-bottom: 14px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 1.75rem;
        }

        /* LESSON */
        .cv-lesson { margin-bottom: 2.25rem; }
        .cv-lesson-meta {
            font-size: 11px; font-weight: 500;
            letter-spacing: .06em; text-transform: uppercase;
            color: var(--accent); margin-bottom: 5px;
        }
        .cv-lesson-title {
            font-family: var(--font-content);
            font-size: 17px; font-weight: 600;
            color: var(--ink); margin-bottom: .75rem;
        }
        .cv-lesson-body {
            font-family: var(--font-content);
            font-size: 15px; line-height: 1.8;
            color: #374151;
        }
        /* Nội dung HTML từ AI */
        .cv-lesson-body h3 {
            font-size: 16px; font-weight: 600;
            margin: 1.25rem 0 .5rem; color: var(--ink);
        }
        .cv-lesson-body h4 {
            font-size: 14px; font-weight: 600;
            margin: 1rem 0 .4rem; color: var(--ink);
        }
        .cv-lesson-body p  { margin-bottom: .75rem; }
        .cv-lesson-body ul { padding-left: 1.5rem; margin-bottom: .75rem; }
        .cv-lesson-body li { margin-bottom: .3rem; }
        .cv-lesson-body code {
            font-family: 'Courier New', monospace;
            font-size: 13px; background: #f3f4f6;
            padding: 1px 5px; border-radius: 4px;
        }
        .cv-lesson-body pre {
            background: #f8fafc;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem 1.25rem;
            overflow-x: auto;
            margin: .75rem 0;
        }
        .cv-lesson-body pre code {
            background: transparent;
            padding: 0; font-size: 13px; line-height: 1.6;
        }

        .cv-empty {
            font-style: italic; color: var(--muted); font-size: 14px;
        }

        .cv-divider {
            border: none; border-top: 1px solid var(--border);
            margin: 2rem 0;
        }

        /* ══════════════════════════════════════════════
           @@media print — ẨN HOÀN TOÀN UI, CHỈ GIỮ NỘI DUNG
        ══════════════════════════════════════════════ */
        @@media print {
            /* Ẩn toàn bộ shell điều hướng */
            .cv-toolbar,
            .cv-sidebar { display: none !important; }

            /* Reset layout về 1 cột */
            body        { background: #fff !important; font-size: 12pt; }
            .cv-layout  { padding-top: 0 !important; display: block !important; }
            .cv-main    { margin-left: 0 !important; padding: 0 !important; max-width: 100% !important; }
            .cv-content-inner { max-width: 100% !important; }

            /* Typography cho bản in */
            .cv-chapter-title { font-size: 16pt !important; }
            .cv-lesson-title  { font-size: 13pt !important; }
            .cv-lesson-body   { font-size: 12pt !important; line-height: 1.6 !important; }

            /* Tránh vỡ tiêu đề & đoạn ngắn */
            .cv-chapter-title,
            .cv-lesson-title,
            h3, h4 { page-break-after: avoid !important; }

            .cv-chapter { page-break-before: always !important; }
            .cv-chapter:first-child { page-break-before: avoid !important; }

            pre { white-space: pre-wrap !important; page-break-inside: auto !important; }

            /* Ẩn badge và divider trang in */
            .cv-chapter-badge { display: none !important; }
        }
    </style>
</head>
<body>

   
    <header class="cv-toolbar">
        <div class="cv-toolbar-left">
            <span class="cv-toolbar-logo">AutoCurriculum</span>
            <div class="cv-toolbar-sep"></div>
            <span class="cv-toolbar-title">@Model.TopicName</span>
        </div>
        <div class="cv-toolbar-actions">
            <a href="/Curriculum/Details?id=@Model.TopicId" class="cv-btn">
                ← Quay lại
            </a>
            <a href="/Export/ExportToPdf?id=@Model.TopicId" class="cv-btn cv-btn-primary">
                ↓ Xuất PDF
            </a>
        </div>
    </header>

    <div class="cv-layout">
       
        <aside class="cv-sidebar">
            <div class="cv-sidebar-header">
                <div class="cv-sidebar-label">Giáo trình</div>
                <div class="cv-sidebar-topic">@Model.TopicName</div>
            </div>

            @if (Model.Chapters != null)
            {
                @foreach (var chapter in Model.Chapters.OrderBy(c => c.ChapterOrder))
                {
                    <div class="cv-toc-chapter">
                        Chương @chapter.ChapterOrder
                    </div>
                    @if (chapter.Lessons != null)
                    {
                        @foreach (var lesson in chapter.Lessons.OrderBy(l => l.LessonOrder))
                        {
                            <a class="cv-toc-lesson"
                               href="#lesson-@chapter.ChapterOrder-@lesson.LessonOrder">
                                @chapter.ChapterOrder.@lesson.LessonOrder — @lesson.LessonTitle
                            </a>
                        }
                    }
                }
            }
        </aside>

  
        <main class="cv-main">
            <div class="cv-content-inner">

                @if (Model.Chapters != null)
                {
                    @foreach (var chapter in Model.Chapters.OrderBy(c => c.ChapterOrder))
                    {
                        <section class="cv-chapter" id="chapter-@chapter.ChapterOrder">

                            <span class="cv-chapter-badge">
                                Chương @chapter.ChapterOrder
                                · @(chapter.Lessons?.Count ?? 0) bài học
                            </span>

                            <h2 class="cv-chapter-title">@chapter.ChapterTitle</h2>

                            @if (chapter.Lessons != null)
                            {
                                @foreach (var lesson in chapter.Lessons.OrderBy(l => l.LessonOrder))
                                {
                                    <article class="cv-lesson"
                                             id="lesson-@chapter.ChapterOrder-@lesson.LessonOrder">

                                        <div class="cv-lesson-meta">
                                            Bài @chapter.ChapterOrder.@lesson.LessonOrder
                                        </div>
                                        <h3 class="cv-lesson-title">@lesson.LessonTitle</h3>

                                        <div class="cv-lesson-body">
                                            @if (lesson.Contents != null && lesson.Contents.Any())
                                            {
                                                @foreach (var content in lesson.Contents)
                                                {
                                                    @Html.Raw(content.ContentText)
                                                }
                                            }
                                            else
                                            {
                                                <p class="cv-empty">
                                                    Nội dung bài học chưa được biên soạn.
                                                </p>
                                            }
                                        </div>

                                    </article>

                                    @if (lesson != chapter.Lessons.OrderBy(l => l.LessonOrder).Last())
                                    {
                                        <hr class="cv-divider" />
                                    }
                                }
                            }

                        </section>
                    }
                }

            </div>
        </main>
    </div>

</body>
</html>