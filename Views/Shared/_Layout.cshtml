@using Microsoft.AspNetCore.Identity
@using AutoCurriculum.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoCurriculum</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        /* Tinh chỉnh nhẹ cho giao diện đẹp hơn */
        body { background-color: #f8f9fa; }
        .navbar { box-shadow: 0 2px 4px rgba(0,0,0,.08); }
        main { background-color: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 0 10px rgba(0,0,0,.05); min-height: 70vh;}
        
        /* Hiệu ứng di chuột cho Navbar */
        .nav-link:hover { color: #0d6efd !important; transition: 0.3s; }
    </style>
</head>
<body >
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom mb-4 sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary fs-4 d-flex align-items-center" 
                href="@(User.Identity?.IsAuthenticated == true 
                            ? (User.IsInRole("Admin") ? "/Admin/Dashboard" : "/Curriculum/Index") 
                            : "/")">
                    <img src="~/images/logo.png" alt="AutoCurriculum Logo" height="70" class="me-2 rounded" />
                    AutoCurriculum
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    
                    <ul class="navbar-nav flex-grow-1 ms-4 fw-medium">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Curriculum" asp-action="Index">
                                    @* <i class="bi bi-journal-text me-1"></i> Quản lý Giáo trình *@
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item me-3">
                                <span class="text-primary fw-bold">
                                    👋 Xin chào, @User.Identity?.Name!
                                </span>
                            </li>
                            <li class="nav-item">
                                <form class="form-inline m-0" asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-outline-danger btn-sm fw-bold rounded-pill px-3">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-primary btn-sm fw-bold px-3 rounded-pill" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-person-circle"></i> Đăng nhập
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-4 bg-white">
        <div class="container text-center">
            <p class="mb-1">&copy; @DateTime.Now.Year - <strong>AutoCurriculum</strong></p>
            <p class="small mb-0">Hệ thống Sinh tạo Giáo trình tự động bằng Trí tuệ Nhân tạo.</p>
        </div>
    </footer>
    
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>