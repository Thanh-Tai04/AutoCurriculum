<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="~/images/logo_small.png">
    <link rel="shortcut icon" href="~/images/logo_small.png" type="image/x-icon">
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* KHÓA CỨNG TOÀN TRANG (Để cuộn từng khung riêng) */
        body { 
            background-color: #f4f7f6; 
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden; 
            height: 100vh;
            margin: 0;
        }
        
        /* ── SIDEBAR ── */
        .sidebar {
            width: 220px;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: #212529;
            color: white;
            z-index: 1050;
            transition: width 0.3s ease;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
            box-shadow: 4px 0 15px rgba(0,0,0,0.1);
        }

        /* Mặc định thu nhỏ */
        .sidebar.collapsed { width: 80px; }
        
        /* ── KHU VỰC LOGO ── */
        .logo-admin {
            height: 120px;
            padding: 15px;
            border-bottom: 1px solid #343a40;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.3s ease;
            background-color: rgba(255,255,255,0.02);
        }
        
        .logo-large { max-width: 160px; max-height: 90px; object-fit: contain; }
        .logo-small { width: 45px; height: 45px; object-fit: contain; display: none; font-size: 1.8rem; color: #0d6efd;}
        
        .sidebar.collapsed .logo-large { display: none; }
        .sidebar.collapsed .logo-small { display: block; }

        /* ── MENU LINKS ── */
        .sidebar-nav { flex-grow: 1; padding-top: 15px; }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.7); 
            padding: 14px 20px; 
            display: flex; 
            align-items: center; 
            gap: 15px; 
            white-space: nowrap; 
            transition: all 0.2s ease;
            border-left: 4px solid transparent;
        }
        .sidebar .nav-link i { font-size: 1.25rem; min-width: 24px; text-align: center; }
        .sidebar.collapsed .nav-link span { display: none; }

        .sidebar .nav-link-btn {
            width: 100%;
            background: none;
            border: none;
            color: rgba(255,255,255,0.7);
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            white-space: nowrap;
            transition: all 0.2s ease;
            border-left: 4px solid transparent;
            text-align: left;
        }

        .sidebar .nav-link-btn:hover {
            color: #ff4d4d;
            background: rgba(255,255,255,0.05);
        }

        .sidebar.collapsed .nav-link-btn span {
            display: none;
        }
        
        .sidebar .nav-link:hover { color: #fff; background: rgba(255,255,255,0.05); }
        .sidebar .nav-link.active { 
            background: #343a40; 
            color: #0d6efd; 
            border-left: 4px solid #0d6efd; 
            font-weight: 600;
        }

        /* ── MAIN CONTENT ── */
        .main-content {
            margin-left: 260px;
            height: 100vh;
            padding: 20px 30px;
            transition: margin-left 0.3s ease;
            display: flex;
            flex-direction: column; 
        }
        .main-content.expanded { margin-left: 80px; }
    </style>
</head>
<body>
    <div class="sidebar collapsed" id="sidebar"> 
        <div class="logo-admin">
            <img src="~/images/logo.png" alt="AutoCurriculum" class="logo-large rounded bg-white p-1" />
            <img src="~/images/logo_small.png" alt="AutoCurriculum" class="logo-small rounded bg-white p-1" />
        </div>

        <nav class="nav flex-column sidebar-nav mt-2">
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" href="/Admin/Dashboard">
                <i class="bi bi-speedometer2"></i> <span>Hệ thống Monitor</span>
            </a>
            
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")" href="/Admin/User">
                <i class="bi bi-people-fill"></i> <span>Quản lý Người dùng</span>
            </a>
            
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Curriculum" ? "active" : "")" href="/Admin/Curriculum">
                <i class="bi bi-book-fill"></i> <span>Quản lý Giáo trình</span>
            </a>
            
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Config" ? "active" : "")" href="/Admin/Config">
                <i class="bi bi-gear-fill"></i> <span>Cấu hình Prompt AI</span>
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ApiKey" ? "active" : "")" href="/Admin/ApiKey">
                <i class="bi bi-key-fill"></i> <span>Quản lý API Key</span>
            </a>
            
            <hr class="mx-3 my-3 text-secondary border-secondary opacity-25">

            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="mt-auto">
                <button type="button" class="nav-link-btn" onclick="confirmLogout()">
                    <i class="bi bi-box-arrow-right text-danger"></i> 
                    <span>Đăng xuất</span>
                </button>
            </form>
        </nav>
    </div>

    <div class="main-content expanded" id="mainContent">
        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        function confirmLogout() {
            Swal.fire({
                title: 'Xác nhận đăng xuất?',
                text: "Bạn sẽ quay trở lại trang giới thiệu hệ thống.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0d6efd', 
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đồng ý, đăng xuất!',
                cancelButtonText: 'Hủy',
                reverseButtons: true 
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('logoutForm').submit();
                }
            });
        }
    </script>

    <script>
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');

        sidebar.addEventListener('mouseenter', function() {
            sidebar.classList.remove('collapsed');
            mainContent.classList.remove('expanded');
        });

        sidebar.addEventListener('mouseleave', function() {
            sidebar.classList.add('collapsed');
            mainContent.classList.add('expanded');
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>