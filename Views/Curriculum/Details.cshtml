@model AutoCurriculum.Models.Topic

@{
    ViewData["Title"] = "Chi tiết giáo trình";
}

<div class="container mt-5 mb-5">
    <a asp-action="Index" class="btn btn-outline-secondary mb-3">&larr; Quay lại danh sách</a>

    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-primary text-white p-4">
            <h2 class="mb-0">📚 @Model.TopicName</h2>
            <small>Ngày tạo: @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
        <div class="card-body p-4">
            <div class="lead" style="white-space: pre-wrap; font-size: 1rem;">@Model.Description</div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-3 border-bottom pb-2">
        <h4 class="text-primary mb-0"><i class="bi bi-journal-bookmark-fill"></i> Cấu trúc Giáo trình</h4>

        <form asp-action="CreateChapter" method="post" class="d-flex">
            <input type="hidden" name="topicId" value="@Model.TopicId" />
            <input type="text" name="chapterTitle" class="form-control form-control-sm me-2" placeholder="Tên chương mới..." required />
            <button type="submit" class="btn btn-success btn-sm">Thêm Chương</button>
        </form>
    </div>

    @if (Model.Chapters != null && Model.Chapters.Any())
    {
        <div class="accordion shadow-sm" id="curriculumAccordion">
            @foreach (var chapter in Model.Chapters.OrderBy(c => c.ChapterOrder))
            {
                string collapseId = "collapse_" + chapter.ChapterId;
                string headingId = "heading_" + chapter.ChapterId;

                <div class="accordion-item">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed fw-bold text-dark bg-light border-bottom" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                            📖 Chương @chapter.ChapterOrder: @chapter.ChapterTitle
                        </button>
                    </h2>

                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#curriculumAccordion">
                        <div class="accordion-body">

                            @if (chapter.Lessons != null && chapter.Lessons.Any())
                            {
                                <ul class="list-group list-group-flush mb-3">
                                    @foreach (var lesson in chapter.Lessons.OrderBy(l => l.LessonOrder))
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center px-1">
                                            <span>📄 <b>@chapter.ChapterOrder.@lesson.LessonOrder </b> @lesson.LessonTitle</span>

                                            <a asp-action="LessonDetails" asp-route-id="@lesson.LessonId" class="btn btn-sm btn-outline-primary rounded-pill">
                                                Vào học / Soạn bài
                                            </a>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted small fst-italic ms-3">Chưa có bài học nào trong chương này.</p>
                            }

                            <div class="d-flex justify-content-between border-top pt-3 mt-2 bg-white">
                                <form asp-action="CreateLesson" method="post" class="d-flex">
                                    <input type="hidden" name="chapterId" value="@chapter.ChapterId" />
                                    <input type="text" name="lessonTitle" class="form-control form-control-sm me-2" placeholder="Tên bài học..." required style="min-width: 250px;" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Thêm bài học</button>
                                </form>

                                <form asp-action="DeleteChapter" asp-route-id="@chapter.ChapterId" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa chương này? Toàn bộ bài học bên trong sẽ bị mất!');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa Chương</button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Chủ đề này chưa có cấu trúc. Hãy thêm chương đầu tiên ở góc trên bên phải!
        </div>
    }
</div>