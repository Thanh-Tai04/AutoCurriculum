@model List<AutoCurriculum.ViewModels.CurriculumIndexViewModel>
@{
    ViewData["Title"] = "Danh sách giáo trình";
}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mt-5">
    <div class="card shadow-sm mb-5">
        <div class="card-body text-center p-5">
            <h1 class="text-primary mb-3">Hệ Thống Tạo Giáo Trình</h1>
            <p class="text-muted">Nhập chủ đề bạn muốn học (Ví dụ: Lập trình Python, ReactJS...)</p>

            <form id="formCreateTopic" class="d-flex justify-content-center mt-4">
                <input type="text" id="txtTopicName" name="topicName" class="form-control w-50 me-2" placeholder="Nhập chủ đề..." required />
                <button type="submit" class="btn btn-primary px-4">Tạo Ngay</button>
            </form>

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success mt-3 d-inline-block">
                    @TempData["Message"]
                </div>
            }
        </div>
    </div>

    <h3 class="mb-3 border-start border-4 border-primary ps-3">Lịch Sử Tạo Giáo Trình</h3>

    <table class="table table-hover border">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tên Chủ Đề</th>
                <th>Ngày Tạo</th>
                <th>Trạng Thái</th>
                <th>Hành Động</th>
            </tr>
        </thead>
        <tbody id="tableBodyTopics">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TopicId</td>
                        <td class="fw-bold text-primary">@item.TopicName</td>
                        <td>@item.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><span class="badge bg-secondary">Mới tạo</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.TopicId" class="btn btn-sm btn-outline-info">Xem chi tiết</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr id="emptyRow">
                    <td colspan="5" class="text-center py-4 text-muted">
                        Chưa có dữ liệu. Hãy nhập chủ đề đầu tiên!
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Bắt sự kiện khi người dùng bấm nút Submit form
            $("#formCreateTopic").submit(async function (e) {
                e.preventDefault(); // CHẶN KHÔNG CHO RELOAD TRANG

                var topicName = $("#txtTopicName").val().trim(); // Lấy giá trị ô nhập
                if (!topicName) return;

                // BƯỚC 1: Hiển thị trạng thái đang tra cứu Wiki & Kiểm duyệt AI
                Swal.fire({
                    title: 'Đang kiểm duyệt & tra cứu...',
                    text: 'Hệ thống đang phân tích từ khóa, vui lòng đợi.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                try {
                    // Gọi API Pre-check bằng Fetch API
                    // LƯU Ý: Sửa lại đường dẫn API cho khớp với Route trong Controller của bạn
                    const response = await fetch(`/Curriculum/PreCheckWiki?topicName=${encodeURIComponent(topicName)}`);
                    const data = await response.json();

                    // Nếu bị BLOCK hoặc không tìm thấy Wiki
                    if (!data.success) {
                        Swal.fire({
                            title: 'Từ chối / Lỗi',
                            text: data.message,
                            icon: 'error',
                            confirmButtonColor: '#d33'
                        });
                        return;
                    }

                    // BƯỚC 2: Hiển thị popup xác nhận dựa trên cờ isWarning
                    let popupTitle = data.isWarning ? 'Cảnh báo nội dung' : 'Xác nhận chủ đề';
                    let popupIcon = data.isWarning ? 'warning' : 'question';
                    let titleColor = data.isWarning ? '#ffc107' : '#0d6efd';
                    let warningMessage = data.isWarning 
                        ? '<p class="text-danger fw-bold mt-2">Nội dung này có thể không phù hợp với mục đích học tập chuẩn mực.</p>' 
                        : '';

                    const result = await Swal.fire({
                        title: popupTitle,
                        html: `
                            <div style="text-align: left;">
                                <h4 style="color: ${titleColor};">${data.exactTitle}</h4>
                                <div style="font-size: 14px; max-height: 150px; overflow-y: auto; background: #f8f9fa; padding: 10px; border-radius: 5px; border: 1px solid #dee2e6;">
                                    ${data.summary}
                                </div>
                                ${warningMessage}
                                <p class="mt-3 mb-0"><strong>Bạn có chắc chắn muốn dùng AI để biên soạn giáo trình này không?</strong></p>
                            </div>
                        `,
                        icon: popupIcon,
                        showCancelButton: true,
                        confirmButtonColor: data.isWarning ? '#ffc107' : '#198754',
                        cancelButtonColor: '#dc3545',
                        confirmButtonText: 'Đồng ý, tạo ngay!',
                        cancelButtonText: 'Hủy bỏ'
                    });

                    // Nếu người dùng bấm Đồng ý -> Tiến hành gọi AI
                    if (result.isConfirmed) {
                        executeAiGeneration(data.exactTitle);
                    }

                } catch (error) {
                    Swal.fire('Lỗi kết nối', 'Không thể kết nối đến máy chủ.', 'error');
                }
            });

            // Hàm thực thi gọi AI và cập nhật giao diện
            function executeAiGeneration(exactTitle) {
                // BƯỚC 3: Hiển thị trạng thái đang gọi AI
                Swal.fire({
                    title: 'AI đang biên soạn giáo trình...',
                    text: 'Quá trình này có thể mất 15 - 30 giây. Vui lòng không đóng trình duyệt.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                // Gọi AJAX đến API Generate như cũ
                $.ajax({
                    url: '/Curriculum/Generate',
                    type: 'POST',
                    data: { topicName: exactTitle },
                    success: function (response) {
                        if (response.success) {
                            // Đóng loading và báo thành công
                            Swal.fire({
                                title: 'Thành công!',
                                text: 'Giáo trình đã được tạo hoàn chỉnh.',
                                icon: 'success',
                                timer: 2000,
                                showConfirmButton: false
                            });

                            $("#txtTopicName").val('');
                            
                            // Xóa dòng "Chưa có dữ liệu" nếu có
                            $("#emptyRow").remove();

                            // Thêm dòng mới vào đầu bảng danh sách
                            var t = response.data;
                            var newRow = `
                                <tr class="table-success">
                                    <td>${t.id}</td>
                                    <td class="fw-bold text-primary">${t.name}</td>
                                    <td>${t.date}</td>
                                    <td><span class="badge bg-success">Vừa tạo xong</span></td>
                                    <td>
                                        <a href="/Curriculum/Details/${t.id}" class="btn btn-sm btn-outline-info">Xem chi tiết</a>
                                    </td>
                                </tr>
                            `;
                            $("#tableBodyTopics").prepend(newRow);

                            setTimeout(function() {
                                $("#tableBodyTopics tr:first").removeClass("table-success");
                            }, 5000);

                        } else {
                            Swal.fire('Lỗi Server', response.message, 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Lỗi kết nối', 'Lỗi kết nối đến máy chủ. Vui lòng thử lại!', 'error');
                    }
                });
            }
        });
    </script>
}