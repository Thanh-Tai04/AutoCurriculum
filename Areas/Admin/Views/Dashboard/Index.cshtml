@model IEnumerable<AutoCurriculum.Models.SystemLog>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ thống Monitor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { 
            background-color: #f4f7f6; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }
        .table {
            margin-bottom: 0;
        }
        .table th {
            background-color: #f8f9fa;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            color: #6c757d;
            padding: 16px 20px;
            border-bottom: 2px solid #e9ecef;
        }
        .table td {
            padding: 16px 20px;
            vertical-align: middle;
        }
        .status-success { color: #198754; font-weight: 600; }
        .status-error { color: #dc3545; font-weight: 600; }
        .badge-action {
            background-color: #e9ecef;
            color: #495057;
            padding: 6px 12px;
            border-radius: 6px;
            font-family: 'Consolas', 'Courier New', monospace;
            font-size: 0.85rem;
            font-weight: 600;
        }
        .btn-config {
            border-radius: 50rem;
            padding: 8px 24px;
            font-weight: 600;
            box-shadow: 0 2px 4px rgba(13, 110, 253, 0.2);
        }
        .btn-config:hover {
            box-shadow: 0 4px 8px rgba(13, 110, 253, 0.3);
            transform: translateY(-1px);
            transition: all 0.2s ease-in-out;
        }
    </style>
</head>
<body class="py-5">
    <div class="container-fluid px-4 px-lg-5"> 
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">🚀 Hệ thống Monitor</h2>
                <p class="text-muted mb-0">Giám sát trực tiếp hoạt động của AI và Wikipedia</p>
            </div>
            <a href="/Admin/Config" class="btn btn-primary btn-config">⚙️ Cấu hình Prompt</a>
        </div>

        <div class="card overflow-hidden">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Thời gian</th>
                                <th>Người dùng</th>
                                <th>Hành động</th>
                                <th>Từ khóa</th>
                                <th>Trạng thái</th>
                                <th>Xử lý</th>
                                <th width="30%">Thông báo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var log in Model)
                                {
                                    <tr>
                                        <td><span class="text-muted">@log.CreatedAt.ToString("HH:mm:ss dd/MM")</span></td>
                                        <td>
                                            <span class="text-primary fw-bold">@(string.IsNullOrEmpty(log.UserEmail) ? "Khách" : log.UserEmail)</span>
                                        </td>
                                        <td><span class="badge-action">@log.Action</span></td>
                                        <td><code>@log.Keyword</code></td>
                                        <td class="@(log.Status == "Success" ? "status-success" : "status-error")">
                                            @(log.Status == "Success" ? "● Thành công" : "● Lỗi")
                                        </td>
                                        <td><span class="fw-semibold">@log.ExecutionTimeMs ms</span></td>
                                        <td class="small text-muted">@log.Message</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">Chưa có dữ liệu nhật ký nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        const refreshInterval = 3000; 

        setInterval(() => {
            fetch(window.location.href) 
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newTbody = doc.querySelector('tbody').innerHTML;
                    document.querySelector('tbody').innerHTML = newTbody;
                })
                .catch(err => console.error('Lỗi khi tự động cập nhật:', err));
        }, refreshInterval);
    </script>
</body>
</html>